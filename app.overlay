/*
 * app.overlay — Heltec WiFi LoRa 32 V3
 * LED onboard sur GPIO1 pin 35 (GPIO_NUM_35)
 */
/ {
    aliases {
        led0 = &user_led;
    };

    leds {
        compatible = "gpio-leds";
        user_led: led_0 {
            gpios = <&gpio1 3 GPIO_ACTIVE_HIGH>;
            label = "User LED";
        };
    };
};
